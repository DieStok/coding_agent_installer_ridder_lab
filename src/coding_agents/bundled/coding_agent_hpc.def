Bootstrap: docker
From: ubuntu:22.04

%labels
    org.label-schema.schema-version 1.0
    org.label-schema.name coding-agents-hpc
    coding-agents.build_date BUILD_DATE_PLACEHOLDER
    coding-agents.versions.ubuntu 22.04
    coding-agents.versions.node 20.x-LTS
    coding-agents.versions.python 3.12.x
    coding-agents.versions.gitleaks 8.21.2
    coding-agents.versions.claude pinned-via-package-lock
    coding-agents.versions.codex pinned-via-package-lock
    coding-agents.versions.opencode pinned-via-package-lock
    coding-agents.versions.pi pinned-via-package-lock
    coding-agents.usage Run from `agent-<name>` wrapper inside `srun --pty`. See docs/v2-deferred.md for v2 scope.

%files
    bundled/sif/package.json /sif-build/package.json
    bundled/sif/package-lock.json /sif-build/package-lock.json

%post
    set -eux

    # System deps
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates curl git jq unzip tar gnupg \
        python3.12 python3.12-venv python3-pip \
        build-essential file
    rm -rf /var/lib/apt/lists/*

    # Node 20 LTS (NodeSource)
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
    apt-get install -y --no-install-recommends nodejs
    rm -rf /var/lib/apt/lists/*
    npm config set unsafe-perm true

    # gitleaks pinned binary (apt path stale on 22.04)
    GITLEAKS_VERSION=8.21.2
    curl -fsSL "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz" -o /tmp/gl.tgz
    # SHA pin: lab admin updates on each gitleaks bump (uncomment + fill)
    # echo "<sha256>  /tmp/gl.tgz" | sha256sum -c -
    tar -xzf /tmp/gl.tgz -C /usr/local/bin gitleaks
    rm /tmp/gl.tgz

    # Coding agents — npm ci against committed lockfile for reproducibility.
    # All four agents installed via npm including @anthropic-ai/claude-code
    # (verified on npm; reproducible inside immutable SIF; DISABLE_AUTOUPDATER
    # set in %environment so the in-binary updater doesn't fight the SIF).
    mkdir -p /opt/agents
    cp /sif-build/package.json /opt/agents/package.json
    cp /sif-build/package-lock.json /opt/agents/package-lock.json
    cd /opt/agents && npm ci --omit=dev --unsafe-perm
    for bin in claude codex opencode pi; do
      ln -sf "/opt/agents/node_modules/.bin/$bin" "/usr/local/bin/$bin"
    done

    # agentuser (uid 1000) with empty $HOME
    useradd -u 1000 -m -s /bin/bash agentuser
    install -d -m 0700 -o agentuser -g agentuser /home/agentuser/.claude

    # Bake resolved versions into /etc/agent-versions for runtime read-back
    {
      echo "build_date=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
      echo "ubuntu=$(. /etc/os-release; echo $VERSION_ID)"
      echo "node=$(node --version)"
      echo "python=$(python3.12 --version | awk '{print $2}')"
      echo "gitleaks=$(gitleaks version)"
      for bin in claude codex opencode pi; do
        v=$($bin --version 2>/dev/null | head -1 || echo unknown)
        echo "${bin}=${v}"
      done
    } > /etc/agent-versions

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PATH=/usr/local/bin:/usr/bin:/bin:/opt/agents/node_modules/.bin
    # Disable Claude Code's in-binary auto-updater inside the immutable SIF
    export DISABLE_AUTOUPDATER=1

%runscript
    exec "$@"
