{
  "description": "Permission deny rules — single source of truth for Claude Code (~/.claude/settings.json permissions.deny). Defence-in-depth on top of the Apptainer cwd-only bind. Codex sandboxing is handled separately via sandbox_mode=workspace-write + [sandbox_workspace_write] in ~/.codex/config.toml (synthesis §3.7); Codex has no path-based deny list.",
  "deny": [
    "Read(./.env)",
    "Read(./.env.*)",
    "Read(./secrets/**)",
    "Read(./config/credentials.json)",
    "Read(./.entire/metadata/**)",
    "Read(./build/**)",
    "Read(~/.ssh/**)",
    "Read(~/.gnupg/**)",
    "Read(~/.irods/**)",
    "Read(~/.aws/**)",
    "Read(~/.kube/**)",
    "Read(~/.config/gcloud/**)",
    "Read(~/.codex/auth.json)",
    "Read(~/.netrc)",
    "Read(~/.config/gh/**)"
  ],
  "claude_code_permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./.entire/metadata/**)",
