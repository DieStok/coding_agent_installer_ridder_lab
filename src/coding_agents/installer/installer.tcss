/* coding-agents installer — minimalist monochrome.
 *
 * Rules:
 *   - Black background, white text, white borders. Everywhere.
 *   - No coloured background fills, no banners with tinted blocks.
 *   - Only buttons carry colour, via Textual's variant=primary/success/error.
 *   - Scrollbars: white track on black.
 */

* {
    scrollbar-color:        white black;
    scrollbar-color-hover:  white black;
    scrollbar-color-active: white black;
    scrollbar-background:        black;
    scrollbar-background-hover:  black;
    scrollbar-background-active: black;
    scrollbar-corner-color: black;
}

Screen {
    align: center middle;
    background: black;
    color: white;
}

Header {
    background: black;
    color: white;
}

Footer {
    background: black;
    color: white;
}

#step-container {
    width: 90;
    max-width: 100%;
    height: auto;
    max-height: 90%;
    background: black;
    color: white;
    border: solid white;
    padding: 1 2;
    overflow-y: auto;
}

.step-title {
    text-style: bold;
    color: white;
    border-bottom: solid white;
    padding: 0 0 1 0;
    margin: 0 0 1 0;
    width: 100%;
}

.step-description {
    color: white;
    margin: 0 0 1 0;
}

.section-heading {
    text-style: bold;
    color: white;
    margin: 1 0 0 0;
}

.section-body {
    margin: 0 0 1 1;
    color: white;
}

.muted {
    color: white 70%;
}

/* Banners reduced to a single white left bar; no fill. */
.banner-info,
.banner-warn,
.banner-success {
    background: black;
    color: white;
    border-left: thick white;
    padding: 0 1;
    margin: 0 0 1 0;
}

/* Nav row */
.nav {
    dock: bottom;
    height: 3;
    padding: 1 0 0 0;
    align: right middle;
    background: black;
}

.nav Button {
    margin: 0 0 0 1;
    min-width: 12;
}

/* Inputs */
Input {
    background: black;
    color: white;
    border: solid white;
    margin: 0 0 1 0;
}

Input:focus {
    border: solid white;
    background: black;
}

/* Selection lists */
SelectionList {
    background: black;
    color: white;
    border: solid white;
    padding: 0 1;
    margin: 0 0 1 0;
    height: auto;
    max-height: 14;
}

RadioSet {
    background: black;
    color: white;
    border: solid white;
    margin: 0 0 1 0;
}

RadioButton {
    background: black;
    color: white;
}

Switch {
    background: black;
}

/* Logs */
#install-log,
#verbose-log {
    background: black;
    color: white;
    border: solid white;
    height: 12;
    margin: 1 0;
}

#verbose-log {
    margin: 0 0 1 0;
    color: white 80%;
}

#install-progress {
    margin: 0 0 1 0;
    width: 100%;
}

ProgressBar > Bar {
    color: white;
    background: black;
}

/* Default Buttons keep their variant colour (primary=blue, success=green,
 * error=red) — that's the only colour in the UI on purpose. */
