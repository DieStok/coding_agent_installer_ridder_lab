/* coding-agents installer — TUI styles.
 *
 * Layout pattern for every step screen:
 *   Vertical #step-container
 *     Label .step-title          <- bold, accent-coloured banner
 *     Static .step-description   <- muted helper text
 *     <screen-specific body>     <- scrolls if too tall
 *     Horizontal .nav            <- docked to bottom, always reachable
 *
 * The .nav docking is the fix for the "I can't see/reach the Next button"
 * problem on small terminals.
 */

Screen {
    align: center middle;
    background: $surface;
}

#step-container {
    width: 90;
    max-width: 100%;
    height: auto;
    max-height: 90%;
    border: round $accent;
    background: $panel;
    padding: 1 2;
    overflow-y: auto;
}

.step-title {
    text-style: bold;
    color: $accent;
    background: $boost;
    padding: 0 1;
    margin: 0 0 1 0;
    width: 100%;
}

.step-description {
    color: $text-muted;
    margin: 0 0 1 0;
}

.section-heading {
    text-style: bold;
    color: $primary;
    margin: 1 0 0 0;
}

.section-body {
    margin: 0 0 1 1;
}

.muted {
    color: $text-muted;
}

.success {
    color: $success;
}

.warning {
    color: $warning;
    text-style: bold;
}

.error {
    color: $error;
    text-style: bold;
}

.banner-info {
    background: $primary 20%;
    border-left: thick $primary;
    padding: 1 2;
    margin: 0 0 1 0;
}

.banner-warn {
    background: $warning 20%;
    border-left: thick $warning;
    padding: 1 2;
    margin: 0 0 1 0;
}

.banner-success {
    background: $success 20%;
    border-left: thick $success;
    padding: 1 2;
    margin: 0 0 1 0;
}

/* Horizontal nav row: always dock to the bottom of the step container so
 * Back/Next/Install/Done are visible even when the body content overflows. */
.nav {
    dock: bottom;
    height: 3;
    padding: 1 0 0 0;
    align: right middle;
    background: $panel;
}

.nav Button {
    margin: 0 0 0 1;
    min-width: 12;
}

/* Inputs */
Input {
    margin: 0 0 1 0;
}

Input:focus {
    border: tall $accent;
}

/* Selection lists with breathing room */
SelectionList {
    border: tall $surface-lighten-1;
    padding: 0 1;
    margin: 0 0 1 0;
    height: auto;
    max-height: 14;
}

RadioSet {
    margin: 0 0 1 0;
}

/* Install log: bigger so progress is visible */
#install-log {
    border: tall $surface-lighten-1;
    height: 18;
    margin: 1 0;
    background: $surface-darken-1;
}
