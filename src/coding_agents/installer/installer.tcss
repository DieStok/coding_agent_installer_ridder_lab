/* coding-agents installer — TUI styles.
 *
 * Design principles:
 *   - Lean on the chosen Textual theme (nord by default) for color harmony.
 *     Don't add custom backgrounds; use borders and text color only.
 *   - One accent color at a time: titles + clickable links use $accent.
 *     Banners use border-left only, no fill.
 *   - .nav docks to the bottom of every step container so navigation
 *     buttons are always reachable even on small terminals.
 */

Screen {
    align: center middle;
}

#step-container {
    width: 90;
    max-width: 100%;
    height: auto;
    max-height: 90%;
    border: round $primary 60%;
    padding: 1 2;
    overflow-y: auto;
}

.step-title {
    text-style: bold;
    color: $accent;
    border-bottom: tall $primary 40%;
    padding: 0 0 1 0;
    margin: 0 0 1 0;
    width: 100%;
}

.step-description {
    color: $text-muted;
    margin: 0 0 1 0;
}

.section-heading {
    text-style: bold;
    color: $primary;
    margin: 1 0 0 0;
}

.section-body {
    margin: 0 0 1 1;
}

.muted {
    color: $text-muted;
    text-style: italic;
}

.success { color: $success; }
.warning { color: $warning; text-style: bold; }
.error   { color: $error;   text-style: bold; }

/* Banners: just a coloured left edge — no background fill, so they don't
 * overpower the rest of the panel. */
.banner-info {
    border-left: thick $primary;
    padding: 0 1;
    margin: 0 0 1 0;
}

.banner-warn {
    border-left: thick $warning;
    padding: 0 1;
    margin: 0 0 1 0;
}

.banner-success {
    border-left: thick $success;
    padding: 0 1;
    margin: 0 0 1 0;
}

/* Nav row: dock bottom so Back/Next/Install/Done are always reachable. */
.nav {
    dock: bottom;
    height: 3;
    padding: 1 0 0 0;
    align: right middle;
}

.nav Button {
    margin: 0 0 0 1;
    min-width: 12;
}

Input {
    margin: 0 0 1 0;
}

Input:focus {
    border: tall $accent;
}

SelectionList {
    border: tall $primary 30%;
    padding: 0 1;
    margin: 0 0 1 0;
    height: auto;
    max-height: 14;
}

RadioSet {
    margin: 0 0 1 0;
}

#install-log {
    border: tall $primary 30%;
    height: 18;
    margin: 1 0;
}
