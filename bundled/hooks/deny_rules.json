{
  "description": "Permission deny rules — single source of truth for both Claude Code (~/.claude/settings.json permissions.deny) and Codex CLI (~/.codex/config.toml [sandbox] deny_paths). Defence-in-depth on top of the Apptainer cwd-only bind.",
  "deny": [
    "Read(./.env)",
    "Read(./.env.*)",
    "Read(./secrets/**)",
    "Read(./config/credentials.json)",
    "Read(./.entire/metadata/**)",
    "Read(./build/**)",
    "Read(~/.ssh/**)",
    "Read(~/.gnupg/**)",
    "Read(~/.irods/**)",
    "Read(~/.aws/**)",
    "Read(~/.kube/**)",
    "Read(~/.config/gcloud/**)",
    "Read(~/.codex/auth.json)",
    "Read(~/.netrc)",
    "Read(~/.config/gh/**)"
  ],
  "claude_code_permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./.entire/metadata/**)",
      "Read(./build/**)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.irods/**)",
      "Read(~/.aws/**)",
      "Read(~/.kube/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.codex/auth.json)",
      "Read(~/.netrc)",
      "Read(~/.config/gh/**)"
    ]
  },
  "codex_config_toml_deny_paths": [
    "./.env",
    "./.env.*",
    "./secrets",
    "./config/credentials.json",
    "./.entire/metadata",
    "./build",
    "~/.ssh",
    "~/.gnupg",
    "~/.irods",
    "~/.aws",
    "~/.kube",
    "~/.config/gcloud",
    "~/.codex/auth.json",
    "~/.netrc",
    "~/.config/gh"
  ]
}
